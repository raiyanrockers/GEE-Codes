// Define the region of interest (roi) for Bangladesh (Dhaka example)
var roi = table;
// Cloud masking function using the MSK_CLASSI_OPAQUE and MSK_CLASSI_CIRRUS bands
function maskClouds(image) {
  var opaqueClouds = image.select('MSK_CLASSI_OPAQUE').neq(1);  // Opaque clouds mask
  var cirrusClouds = image.select('MSK_CLASSI_CIRRUS').neq(1);  // Cirrus clouds mask

  // Combine the masks for both opaque and cirrus clouds
  var mask = opaqueClouds.and(cirrusClouds);

  // Apply the mask and scale the image by 10000 to normalize reflectance values
  return image.updateMask(mask).divide(10000);
}


// Load Sentinel-2 L1C image collection for a fixed date (August 2023)
var sentinel2 = ee.ImageCollection('COPERNICUS/S2')  // Use Sentinel-2 L1C (Top of Atmosphere)
  .filterBounds(roi)  // Filter to your region of interest
  .filterDate('2024-10-12', '2024-10-25')  // Adjusted date range to ensure data is available
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 30))  // Pre-filter by cloud cover percentage
  .map(maskClouds);  // Apply cloud masking
