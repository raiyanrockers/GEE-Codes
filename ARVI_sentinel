// Check if any images are available for the given date
var image = sentinel2.median(). clip(roi);

if (image) {
  // Sentinel-2 bands: NIR (B8), Red (B4), Blue (B2)
  var nir = image.select('B8');  // Near-Infrared band
  var red = image.select('B4');  // Red band
  var blue = image.select('B2');  // Blue band

  // Calculate ARVI
  var arvi = image.expression(
    '((NIR - 2 * RED + BLUE) / (NIR + 2 * RED - BLUE))', {
      'NIR': nir,
      'RED': red,
      'BLUE': blue
    }
  );
 // Calculate the minimum and maximum ARVI values within the region
  var stats = arvi.reduceRegion({
    reducer: ee.Reducer.minMax(),
    geometry: roi,  // User's predefined ROI
    scale: 10,  // Use 10-meter scale for Sentinel-2 resolution
    maxPixels: 1e9
  });

  // Print the raw stats result to inspect the keys directly
  print('Raw stats result:', stats);
  // Display the ARVI result with a green-to-red palette
  Map.centerObject(roi, 10);
  Map.addLayer(arvi, {min: -1, max: 1, palette: ['blue', 'white', 'green']}, 'ARVI');

  // Optional: Export ARVI image to Google Drive
  Export.image.toDrive({
    image: arvi,
    description: 'Post_ARVI_Helene',
    scale: 10,  // Sentinel-2 has a 10m resolution for B8, B4, and B2
    region: roi,
    maxPixels: 1e9
  });
} else {
  print('No Sentinel-2 images found for the specified date.');
}
